{
	"name": "dhugs-com",
	"version": "3.2.1",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "npx wrangler types --env-interface CloudflareEnv ./env.d.ts && next build",
		"build:prod": "npx opennextjs-cloudflare build",
		"build:dev": "npx opennextjs-cloudflare build --env dev",
		"start": "next start",
		"lint": "eslint app lib",
		"test": "vitest run --passWithNoTests",
		"test:e2e": "vitest run tests/e2e/",
		"test:e2e:dev": "TEST_ENV=dev vitest run tests/e2e/",
		"test:e2e:prod": "TEST_ENV=prod vitest run tests/e2e/",
		"test:e2e:watch": "HEADED=1 vitest run tests/e2e/",
		"test:e2e:dev:watch": "HEADED=1 TEST_ENV=dev vitest run tests/e2e/",
		"test:e2e:prod:watch": "HEADED=1 TEST_ENV=prod vitest run tests/e2e/",
		"preview": "npm run build:prod && npx opennextjs-cloudflare preview",
		"deploy": "npm run build:prod && npx opennextjs-cloudflare deploy",
		"preview:dev": "npm run build:dev && npx opennextjs-cloudflare preview --env dev",
		"deploy:dev": "npm run build:dev && npx opennextjs-cloudflare deploy --env dev",
		"cf-typegen": "npx wrangler types --env-interface CloudflareEnv ./env.d.ts",
		"db:migration:new": "npx wrangler d1 migrations create D1_POSTS",
		"db:migrate": "npx wrangler d1 migrations apply D1_POSTS",
		"db:migrate:remote": "npx wrangler d1 migrations apply D1_POSTS --remote",
		"db:upsert:post": "tsx scripts/db-upsert-post.ts",
		"db:upsert:album": "tsx scripts/db-upsert-album.ts",
		"db:delete:post": "tsx scripts/db-delete-post.ts",
		"content:sitemap": "tsx scripts/generate-sitemap.ts",
		"content:redirects": "tsx scripts/generate-redirects.ts",
		"content:images": "tsx scripts/generate-image-versions.ts",
		"prepare:album": "node scripts/prepare-album-folder.js",
		"publish:album": "node scripts/publish-album.js",
		"publish:albums:batch": "node scripts/publish-albums-batch.js",
		"publish:post": "node scripts/publish-post.js",
		"publish:portfolio": "node scripts/publish-portfolio.js",
		"publish:home-thumb": "node scripts/publish-home-thumbnail.js",
		"db:edit:tags": "node scripts/edit-post-tags.js",
		"link:add": "tsx scripts/add-link.ts",
		"cdn:robots:disallow": "tsx scripts/upload-cdn-robots.ts disallow",
		"cdn:robots:allow": "tsx scripts/upload-cdn-robots.ts allow",
		"browse": "TEST_ENV=local vitest run tests/e2e/site.test.ts",
		"upgrade": "npx npm-check-updates -u && npm install",
		"release": "./scripts/version-bump.sh patch",
		"release:minor": "./scripts/version-bump.sh minor",
		"release:major": "./scripts/version-bump.sh major"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1024.0",
		"@chenglou/pretext": "^0.0.4",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^17.4.0",
		"enquirer": "^2.4.1",
		"gray-matter": "^4.0.3",
		"next": "16.2.2",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-rehype": "^11.1.2",
		"sitemap": "^9.0.1",
		"yet-another-react-lightbox": "^3.30.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.2",
		"@opennextjs/cloudflare": "^1.18.0",
		"@tailwindcss/postcss": "^4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.5.2",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"eslint": "^10.2.0",
		"execa": "^9.6.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^4",
		"tsx": "^4.21.0",
		"typescript": "^6",
		"vibium": "^26.3.18",
		"vitest": "^4.1.2",
		"wrangler": "^4.80.0"
	}
}
