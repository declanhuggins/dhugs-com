{
	"name": "dhugs-com",
	"version": "3.1.1",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "npx wrangler types --env-interface CloudflareEnv ./env.d.ts && next build",
		"build:prod": "npx opennextjs-cloudflare build --env prod",
		"build:dev": "npx opennextjs-cloudflare build --env dev",
		"start": "next start",
		"lint": "eslint app lib",
		"test": "vitest run --passWithNoTests",
		"preview": "npm run build:prod && npx opennextjs-cloudflare preview --env prod",
		"deploy": "npm run build:prod && npx opennextjs-cloudflare deploy --env prod",
		"upload": "npm run build:prod && npx wrangler upload -e prod",
		"preview:dev": "npm run build:dev && npx opennextjs-cloudflare preview --env dev",
		"deploy:dev": "npm run build:dev && npx opennextjs-cloudflare deploy --env dev",
		"upload:dev": "npm run build:dev && npx wrangler upload -e dev",
		"cf-typegen": "npx wrangler types --env-interface CloudflareEnv ./env.d.ts",
		"assets:ignore": "mkdir -p .vercel/output/static && printf '_worker.js\n' > .vercel/output/static/.assetsignore",
		"db:migration:new": "npx wrangler d1 migrations create D1_POSTS",
		"db:migrate": "npx wrangler d1 migrations apply D1_POSTS",
		"db:migrate:remote": "npx wrangler d1 --env prod migrations apply D1_POSTS --remote",
		"db:upsert:post": "tsx scripts/db-upsert-post.ts",
		"db:upsert:album": "tsx scripts/db-upsert-album.ts",
		"db:delete:post": "tsx scripts/db-delete-post.ts",
		"content:all": "npm run content:postsJson && npm run content:albumsIndex && npm run content:searchIndex && npm run content:sitemap && npm run content:redirects && npm run content:randomImage",
		"content:redirects": "tsx scripts/generate-redirects.ts",
		"content:sitemap": "tsx scripts/generate-sitemap.ts",
		"content:searchIndex": "tsx scripts/generate-search-index.ts",
		"content:postsJson": "tsx scripts/generate-posts-json.ts",
		"content:albumsIndex": "tsx scripts/generate-album-index.ts",
		"content:randomImage": "tsx scripts/generate-random-image-json.ts",
		"content:images": "tsx scripts/generate-image-versions.ts",
		"albums:backfill:manifests": "tsx scripts/backfill-album-manifests.ts",
		"prepare:album": "node scripts/prepare-album-folder.js",
		"publish:album": "node scripts/publish-album.js",
		"publish:albums:batch": "node scripts/publish-albums-batch.js",
		"publish:post": "node scripts/publish-post.js",
		"publish:portfolio": "node scripts/publish-portfolio.js",
		"publish:home-thumb": "node scripts/publish-home-thumbnail.js",
		"db:edit:tags": "node scripts/edit-post-tags.js",
		"link:add": "tsx scripts/add-link.ts",
		"cdn:robots:disallow": "tsx scripts/upload-cdn-robots.ts disallow",
		"cdn:robots:allow": "tsx scripts/upload-cdn-robots.ts allow",
		"browse": "tsx scripts/selenium-browse.ts",
		"upgrade": "npx npm-check-updates -u && npm install"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1009.0",
		"date-fns-tz": "^3.2.0",
		"dotenv": "^17.3.1",
		"enquirer": "^2.4.1",
		"gray-matter": "^4.0.3",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-photo-album": "^3.5.1",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-html": "^16.0.1",
		"remark-rehype": "^11.1.2",
		"sitemap": "^9.0.1",
		"yet-another-react-lightbox": "^3.29.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.1.6",
		"@opennextjs/cloudflare": "^1.17.1",
		"@tailwindcss/postcss": "^4",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.5.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/selenium-webdriver": "^4.35.5",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"esbuild": "^0.27.4",
		"eslint": "^10.0.3",
		"execa": "^9.6.1",
		"npm-check-updates": "^19.6.3",
		"selenium-webdriver": "^4.41.0",
		"sharp": "^0.34.5",
		"tailwindcss": "^4",
		"tar": "^7.5.11",
		"tsx": "^4.21.0",
		"typescript": "^5",
		"vitest": "^4.1.0",
		"wrangler": "^4.73.0"
	}
}
